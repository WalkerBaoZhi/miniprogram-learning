/* pages/map/map.wxss */
.container {
    padding: 20rpx 0;
}

.h1 {
    font-size: 1.5rem;
    margin: 20rpx 30rpx 10rpx;
}

.section {
    margin: 0 30rpx;
}

.map-demo {
    width: 100%;
    height: 500rpx;
    border-radius: 10rpx;
}

.ctrl-row {
    display: flex;
    flex-wrap: wrap;
    gap: 15rpx;
    margin: 20rpx 30rpx;
}

.ctrl-btn {
    flex: 1;
    min-width: 120rpx;
    font-size: 0.9rem;
    border-radius: 10rpx;
    background-color: #07C160;
    color: white;
}

.status {
    margin: 10rpx 30rpx;
    padding: 15rpx;
    background-color: #f0f9eb;
    border-radius: 10rpx;
    color: #67c23a;
    font-size: 0.9rem;
}

.info {
    display: flex;
    flex-direction: column;
    gap: 10rpx;
    margin: 20rpx 30rpx;
    padding: 20rpx;
    background-color: #f5f5f5;
    border-radius: 10rpx;
    font-size: 0.9rem;
    color: #333;
}