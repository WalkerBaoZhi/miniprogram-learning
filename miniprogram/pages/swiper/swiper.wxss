/* pages/swiper/swiper.wxss */
.slide-image {
    width: 100%;
    height: auto;
}

.roll-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-block: 10rpx;
}

.row-container {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    /* justify-content: space-between; */
    margin-right: 10rpx;
}

view {
    color: white;
    font-size: 45rpx;
    text-align: center;
}

input {
    background-color: rgba(128, 255, 212, 0.3);
    width: 30%;
    height: auto;
    border-radius: 6rpx;
    text-align: center;
    margin-left: 20rpx;
    margin-right: 20rpx;
}

switch {
    margin-left: 10rpx;
    margin-right: 10rpx;
}