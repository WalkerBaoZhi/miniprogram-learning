<swiper
    indicator-dots="{{dots}}"
    autoplay="{{autoplay}}"
    interval="{{interval}}"
    duration="{{duration}}"
    style="height: {{currentHeight}};"
    bindchange="onSwiperChange">
    <block wx:for="{{imagelist}}">
        <swiper-item>
            <image src="{{item}}" class="slide-image" mode="widthFix"/>
        </swiper-item>
    </block>
</swiper>

<view style="height: 40px;"></view>

<view class="roll-container">
    <view class="row-container">
        <view>自动播放</view>
        <switch checked="{{autoplay}}" bindchange="onSwitchChange"/>
    </view>
    <view class="row-container">
        <view>播放间隔时间</view>
        <input type="number" value="{{display_interval_time}}" bindinput="onInputChange" />
        <view>秒</view>
    </view>
</view>