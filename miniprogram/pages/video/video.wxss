/* pages/video/video.wxss */
.container {
    padding: 20rpx 0;
}

.h1 {
    font-size: 1.5rem;
    margin: 20rpx 30rpx 10rpx;
}

.section {
    margin: 20rpx 30rpx;
    padding: 20rpx;
    border: 2rpx solid #eee;
    border-radius: 10rpx;
}

.section-title {
    font-size: 1rem;
    color: #666;
    margin-bottom: 15rpx;
}

.video-demo {
    width: 100%;
    height: 400rpx;
}

.video-ctrl {
    display: flex;
    align-items: center;
    gap: 15rpx;
    margin-top: 15rpx;
}

.ctrl-btn {
    flex: 1;
    font-size: 0.9rem;
    border-radius: 10rpx;
}

.ctrl-label {
    font-size: 0.9rem;
    color: #333;
}
