/* pages/image/image.wxss */
.h1 {
    font-size: 1.5rem;
    margin: 20rpx 30rpx 10rpx;
}

.section {
    margin: 20rpx 30rpx;
    padding: 20rpx;
    border: 2rpx solid #eee;
    border-radius: 10rpx;
}

.section-title {
    font-size: 1rem;
    color: #666;
    margin-bottom: 15rpx;
}

.img-demo {
    width: 100%;
    height: 300rpx;
    background-color: #f0f0f0;
}

.img-lazy {
    width: 100%;
    height: 400rpx;
    background-color: #f0f0f0;
}
