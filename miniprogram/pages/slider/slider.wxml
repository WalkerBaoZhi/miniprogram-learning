<!--pages/slider/slider.wxml-->
<view class="container">
    <view class="icon-wrapper">
        <icon type="success" size="{{iconSize}}" color="{{iconColor}}" />
    </view>

    <view class="slider-group">
        <view class="slider-row">
            <text class="slider-label">大小: {{iconSize}}</text>
            <slider show-value min="20" max="100" step="5" value="{{iconSize}}" bindchanging="onSizeChange" />
        </view>
        <view class="slider-row">
            <text class="slider-label">颜色: {{iconColor}}</text>
            <slider min="0" max="360" value="{{colorHue}}" show-value step="60" bindchanging="onColorChange" />
        </view>
    </view>
</view>