/* pages/input/input.wxss */
.table {
    margin: 10rpx;
    display: table;
    width: 100%;
    border-collapse: collapse;
  }
  
  .tr {
    display: table-row;
  }
  
  .td {
    display: table-cell;
    padding: 10rpx 20rpx;
    border: 1px solid #ccc;
    font-size: 28rpx;
  }
  
  .th .td {
    font-weight: bold;
    background: #f5f5f5;
  }
  