/* pages/location/location.wxss */
.container {
    padding: 20rpx 0;
}

.h1 {
    font-size: 1.5rem;
    margin: 20rpx 30rpx 10rpx;
}

.btn-group {
    display: flex;
    flex-direction: column;
    gap: 15rpx;
    margin: 20rpx 30rpx;
}

.btn {
    border-radius: 10rpx;
    color: white;
}

.btn.primary {
    background-color: #07C160;
}

.btn.danger {
    background-color: #e64340;
}

.info-card {
    margin: 20rpx 30rpx;
    padding: 25rpx;
    background-color: #f5f5f5;
    border-radius: 10rpx;
}

.info-row {
    display: flex;
    justify-content: space-between;
    padding: 15rpx 0;
    border-bottom: 1rpx solid #e0e0e0;
}

.info-row:last-child {
    border-bottom: none;
}

.info-label {
    font-size: 1rem;
    color: #666;
}

.info-value {
    font-size: 1rem;
    color: #333;
    font-weight: bold;
}

.empty {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 200rpx;
    color: #999;
    font-size: 0.9rem;
}
