/* pages/radio/radio.wxss */
.container {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.radio-item, .checkbox-item {
  display: inline-block;
  margin-right: 40rpx;
  font-size: 30rpx;
}

button {
  margin-top: 40rpx;
}

.result {
  margin-top: 60rpx;
  padding: 30rpx;
  border: 2rpx solid #000;
  border-radius: 10rpx;
}

.result-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #ddd;
  padding-bottom: 15rpx;
}

.result-item {
  font-size: 30rpx;
  margin: 15rpx 0;
}