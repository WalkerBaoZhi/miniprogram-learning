<view class="container">
  <view class="user-section">
    <!-- 未登录 -->
    <view wx:if="{{!isLoggedIn && !loading}}" class="login-card">
      <view class="login-avatar">
        <image src="../../images/icons/usercenter.png" class="avatar-icon" />
      </view>
      <text class="login-title">HelloWorld</text>
      <text class="login-desc">登录以使用完整功能</text>
      <button class="login-btn" bind:tap="onLogin">登录</button>
    </view>

    <!-- 已登录 -->
    <view wx:else class="user-card">
      <view class="avatar-display">
        <image src="{{userInfo.avatarUrl || '../../images/icons/avatar.png'}}" class="avatar-image" mode="aspectFill" />
      </view>
      <view class="nickname-row">
        <text class="nickname-text">{{userInfo.nickName}}</text>
        <button class="edit-btn" bind:tap="showEditProfile">编辑</button>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-section">
    <text>加载中...</text>
  </view>

  <!-- 退出登录 -->
  <view wx:if="{{isLoggedIn}}" class="footer-section">
    <button class="logout-btn" bind:tap="onLogout">退出登录</button>
  </view>
</view>

<!-- 编辑资料弹窗 -->
<view wx:if="{{showEditModal}}" class="edit-overlay" bind:tap="hideEditProfile"></view>
<view class="edit-popup {{showEditModal ? 'edit-popup-open' : ''}}">
  <view class="edit-popup-header">
    <text class="edit-popup-title">编辑资料</text>
    <text class="close-btn" bind:tap="hideEditProfile">关闭</text>
  </view>
  <view class="edit-popup-body">
    <view class="edit-avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onEditChooseAvatar">
        <image src="{{editAvatarUrl || userInfo.avatarUrl || '../../images/icons/avatar.png'}}" class="avatar-image" mode="aspectFill" />
      </button>
      <text class="edit-avatar-hint">点击头像更换</text>
    </view>
    <view class="form-group">
      <text class="form-label">昵称</text>
      <input class="form-input" type="nickname" placeholder="请输入昵称" value="{{editNickName}}" bindinput="onEditNickNameInput" />
    </view>
    <button class="save-btn" bind:tap="saveEditProfile">保存</button>
  </view>
</view>
