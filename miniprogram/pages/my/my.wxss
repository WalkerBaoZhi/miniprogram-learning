.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.user-section {
  width: 100%;
}

.login-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 96rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
}

.login-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  width: 80rpx;
  height: 80rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.login-desc {
  font-size: 28rpx;
  color: #999;
}

.login-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  color: #fff;
  text-align: center;
  margin-top: 16rpx;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.8;
}

.user-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
}

.avatar-display {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #e8f5e9;
}

.avatar-image {
  width: 160rpx;
  height: 160rpx;
  display: block;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nickname-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.edit-btn {
  font-size: 24rpx;
  color: #07c160;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.edit-btn::after {
  border: none;
}

.loading-section {
  padding: 64rpx 0;
  color: #999;
  font-size: 28rpx;
}

.footer-section {
  width: 100%;
  margin-top: 48rpx;
  display: flex;
  justify-content: center;
}

.logout-btn {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  border: 2rpx solid #e34d59;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #e34d59;
  text-align: center;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  opacity: 0.7;
}

/* 编辑弹窗 */
.edit-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.edit-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 300;
  transform: translateY(100%);
  transition: transform 0.25s ease;
  max-height: 80vh;
  overflow-y: auto;
}

.edit-popup-open {
  transform: translateY(0);
}

.edit-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.edit-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  font-size: 28rpx;
  color: #999;
}

.edit-popup-body {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.edit-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.edit-avatar-hint {
  font-size: 24rpx;
  color: #999;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  overflow: hidden;
  padding: 0;
  margin: 0;
  line-height: 1;
  background: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.avatar-btn::after {
  border: none;
}

.form-group {
  width: 100%;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  color: #fff;
  text-align: center;
  margin-top: 16rpx;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  opacity: 0.8;
}
